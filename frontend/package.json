{
  "name": "hotelease-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . && npm run lint:i18n-booking",
    "lint:i18n-booking": "node scripts/check-booking-hardcoded-fr.cjs",
    "preview": "vite preview",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "test:all": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -NoProfile -Command \"Set-Location ..\\backend; & 'C:\\xampp\\php\\php.exe' artisan test; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; Set-Location ..\\frontend; npm run e2e\""
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "axios": "^1.6.7",
    "chart.js": "^4.4.2",
    "leaflet": "^1.9.4",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-chartjs": "^5.3.0",
    "vue-i18n": "^9.9.1",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.53.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.18",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.5",
    "vite-imagetools": "^7.0.0",
    "vue-eslint-parser": "^10.4.0"
  }
