							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nom\": \"Benhamida\",\n  \"prenom\": \"Malek\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\",\n  \"password_confirmation\": \"Password123!\",\n  \"telephone\": \"12345678\",\n  \"role\": \"client\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/register" }
					}
				},
				{
					"name": "Login",
					"request": {
