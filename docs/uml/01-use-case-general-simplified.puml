@startuml
left to right direction
skinparam shadowing false
skinparam actorStyle awesome
skinparam roundcorner 10
skinparam backgroundColor #FFFFFF

scale 2
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #888888
  FontSize 35
  FontName Arial
}
skinparam actor {
  BackgroundColor #FFFFFF
  BorderColor #666666
  FontSize 35
  FontName Arial
}
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor #CCBB88
  FontSize 30
  FontName Arial
}
skinparam rectangle {
  FontSize 40
  FontName Arial
  BorderColor #444444
}
skinparam ArrowColor #888888
skinparam ArrowFontSize 28

actor "Client" as Client
actor "Visiteur" as Visiteur
actor "Réceptionniste" as Recep
actor "Administrateur" as Admin
actor "Responsable Marketing" as Marketing

' Héritage : Le client peut faire tout ce que le visiteur fait
Client --|> Visiteur

rectangle "Gestion de l'Application HotelEase" {

    ' Actions du Visiteur / Client
    (Consulter hôtels et disponibilités) as UC_Consulter
    (Services et Chatbot IA) as UC_IA
    (Effectuer une réservation) as UC_Reserve

    ' Actions du Réceptionniste
    (Gestion des Réservations) as UC_G_Reserve

    ' Actions de l'Administrateur
    (Gestion Administrative) as UC_Admin
    (Gestion des Utilisateurs) as UC_Users

    ' Actions Marketing
    (Marketing et Feedback) as UC_Market

    ' Notes identiques à ton image originale
    note right of UC_IA : - Consulter les services (Spa, Resto)\n- Chatbot IA réservé aux clients
    note right of UC_G_Reserve : - Gérer / confirmer / annuler\n- check-in / check-out
    note right of UC_Admin : - Mise à jour tarifs/chambres\n- Validation des demandes

    ' Liaisons
    Visiteur --> UC_Consulter

    ' Ajout de la liaison de réservation pour le client
    Client --> UC_IA
    Client --> UC_Reserve

    Recep --> UC_G_Reserve

    Admin --> UC_Admin
    Admin --> UC_Users

    Marketing --> UC_Market
}
@enduml
