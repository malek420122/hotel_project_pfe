@startuml
left to right direction
skinparam shadowing false
skinparam actorStyle default
skinparam roundcorner 10

' --- ACTEURS ---
actor "Client" as Client
entity "Passerelle de Paiement" as Stripe <<System>>
entity "Assistant IA" as Chatbot <<System>>
entity "Moteur de Suggestion" as Reco <<System>>

rectangle "Gestion des Réservations et Paiments" {
    
    ' --- RECHERCHE & RECOMMANDATION ---
    (Rechercher et Filtrer) as UC_Search
    (Consulter les recommandations) as UC_Reco
    
    ' --- RÉSERVATION & PAIEMENT ---
    (Effectuer une réservation) as UC_Book
    (Gérer les demandes spéciales) as UC_Special
    (Appliquer un code promo) as UC_Promo
    (Payer la réservation) as UC_Pay
    
    ' --- GESTION DES RÉSERVATIONS ---
    (Gérer ses réservations) as UC_Manage
    (Consulter par statut) as UC_View
    (Modifier une réservation) as UC_Modify
    (Annuler une réservation) as UC_Cancel
    (Télécharger la facture) as UC_Invoice
    
    ' --- FIDÉLITÉ & SUPPORT ---
    (Gérer son programme fidélité) as UC_Loyalty
    (Échanger des points) as UC_Redeem
    (Utiliser le chatbot IA) as UC_Chatbot

    ' --- LIAISONS CLIENT ---
    Client --> UC_Search
    Client --> UC_Reco
    Client --> UC_Book
    Client --> UC_Manage
    Client --> UC_Loyalty
    Client --> UC_Chatbot

    ' --- RELATIONS INTERNES ---
    UC_Book ..> UC_Pay : <<include>>
    UC_Special ..> UC_Book : <<extend>>
    UC_Promo ..> UC_Pay : <<extend>>
    
    UC_Manage ..> UC_View : <<include>>
    UC_Manage ..> UC_Modify : <<include>>
    UC_Manage ..> UC_Cancel : <<include>>
    UC_Manage ..> UC_Invoice : <<include>>
    
    UC_Redeem ..> UC_Loyalty : <<extend>>
    UC_Loyalty ..> UC_Promo : <<extend>>

    ' --- LIAISONS SYSTÈMES ---
    UC_Pay -- Stripe
    UC_Chatbot -- Chatbot
    UC_Reco -- Reco

    ' --- NOTES DE PRÉCISION ---
    note top of UC_Cancel
      **Conditions d'annulation :**
      - Remboursement total (J-48h)
      - Frais de 50% (J-24h)
    end note

    note right of UC_View
      **Statuts :** En cours, 
      Annulés ou Passés.
    end note

    note right of UC_Modify
      Ex: Changer les dates, 
      type de chambre, nombre de personnes.
    end note

    note right of UC_Special
      Ex: Lit bébé, Allergies, 
    end note

    note bottom of UC_Chatbot
      Message envoyé à la réception 
      pour traitement.
    end note

    note right of UC_Redeem
      Ex: Échange 1000 points 
      pour une réduction de 10%.
    end note
}
@enduml